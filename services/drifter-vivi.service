[Unit]
Description=MZ1312 DRIFTER Vivi v2 Voice Assistant
After=nanomq.service sound.target
Wants=nanomq.service
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=/opt/drifter
ExecStart=/opt/drifter/venv/bin/python3 /opt/drifter/vivi_v2.py
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/opt/drifter/.env

# Vehicle-survival hardening 2026-05-20: cap vivi to ~1.5G hard /
# 1.2G soft. Ollama llm runtime is intentionally uncapped; total RAM
# budget assumes vivi+dashboard+rfaudio caps absorb other growth.
MemoryHigh=1.2G
MemoryMax=1.5G
TasksMax=256

# RAM-survival hardening 2026-06-10: heavy/sacrificial tier.
# OOMScoreAdjust=+500 so the kernel kills vivi BEFORE the diag/safety
# core (at -800). Vivi is out-of-process to ollama; the 1.5G cap covers
# its audio/wake buffers, not the LLM runtime. See
# drifter-canbridge.service for the full OOM-priority scheme.
OOMScoreAdjust=500

[Install]
WantedBy=multi-user.target
