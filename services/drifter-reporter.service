[Unit]
Description=MZ1312 DRIFTER Session Reporter (Tier 3)
After=nanomq.service
Wants=nanomq.service
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=/opt/drifter
ExecStart=/opt/drifter/venv/bin/python3 /opt/drifter/session_reporter.py
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/opt/drifter/.env

# RAM-survival hardening 2026-06-10: heavy/sacrificial tier. Reporter
# talks to ollama out-of-process (own RSS modest, ~300-500M) — 512M
# leaves headroom for markdown/LLM-response buffers without ever covering
# ollama. OOMScoreAdjust=+500 makes the kernel kill this BEFORE the
# diag/safety core (which sits at -800). See drifter-canbridge.service
# for the full OOM-priority scheme.
MemoryMax=512M
OOMScoreAdjust=500

[Install]
WantedBy=multi-user.target
