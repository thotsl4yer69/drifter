[Unit]
Description=MZ1312 DRIFTER Watchdog — Service & System Health Monitor
After=nanomq.service drifter-canbridge.service
Wants=nanomq.service
# Vehicle-survival hardening 2026-06-10: NO StartLimitAction=reboot-force.
# The watchdog's real job is restarting individual wedged units (it only ever
# runs `systemctl restart <unit>`, never reboots). The systemd reboot-force
# fired only if the watchdog *process itself* crash-looped — which a reboot
# can't fix (code/config/broker-at-boot), so it would loop and brick the node.
# Restart=on-failure (below) recovers a transient crash without ever escalating
# to a node reboot.

[Service]
Type=simple
WorkingDirectory=/opt/drifter
ExecStart=/opt/drifter/venv/bin/python3 /opt/drifter/watchdog.py
Restart=on-failure
RestartSec=10
Environment=PYTHONUNBUFFERED=1

# Vehicle-survival hardening 2026-05-20: without the watchdog there
# is no flap-detection or telemetry-health observability — bias the
# global OOM killer away from us. See progress.txt for context.
OOMScoreAdjust=-500

# --- Hardening (see AGENTS.md) --------------------------------------
# Baseline sandboxing. ProtectSystem=full makes /usr, /boot, /etc
# read-only while leaving /opt/drifter writable for logs/state.
NoNewPrivileges=true
ProtectHome=true
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
ProtectSystem=full
LockPersonality=true
RestrictSUIDSGID=true

[Install]
WantedBy=multi-user.target
