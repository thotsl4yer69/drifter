[Unit]
Description=MZ1312 DRIFTER Replay + Recorder
After=nanomq.service
Wants=nanomq.service
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
WorkingDirectory=/opt/drifter
ExecStart=/opt/drifter/venv/bin/python3 /opt/drifter/replay_engine.py
ExecStartPost=/bin/sh -c '/opt/drifter/venv/bin/python3 /opt/drifter/session_recorder.py &'
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
