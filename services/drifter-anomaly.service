[Unit]
Description=DRIFTER Anomaly Monitor
After=network.target drifter-canbridge.service
Wants=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/drifter
EnvironmentFile=-/opt/drifter/.env
ExecStart=/opt/drifter/venv/bin/python3 /opt/drifter/anomaly_monitor.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
