#!/usr/bin/env python3
"""
drifter-ble-export — dump BLE detection history for post-drive review.

Usage:
  drifter-ble-export [--since 24h] [--until now] [--target axon]
                     [--drive-id drive-...] [--format csv|geojson|json]
                     [--out FILE]

Exit codes:
  0  rows written
  2  no rows matched the filters
  1  unexpected error

UNCAGED TECHNOLOGY — EST 1991
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

# Run from /opt/drifter when symlinked at /usr/local/bin/drifter-ble-export.
DRIFTER_DIR = Path("/opt/drifter")
if DRIFTER_DIR.exists() and str(DRIFTER_DIR) not in sys.path:
    sys.path.insert(0, str(DRIFTER_DIR))

import ble_history  # noqa: E402

DEFAULT_DB = Path("/opt/drifter/state/ble_history.db")


def parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        prog='drifter-ble-export',
        description='Dump BLE detection history for forensic review.',
    )
    p.add_argument('--since', help='Lower-bound time (e.g. 24h, 7d, 2026-05-01)')
    p.add_argument('--until', help='Upper-bound time (same syntax as --since)')
    p.add_argument('--target', help='Filter by target name (e.g. axon)')
    p.add_argument('--drive-id', dest='drive_id', help='Filter to one drive')
    p.add_argument('--format', choices=('csv', 'geojson', 'json'),
                   default='csv', help='Output format (default csv)')
    p.add_argument('--out', help='Output file (default stdout)')
    p.add_argument('--limit', type=int, default=10000,
                   help='Hard row cap (default 10000)')
    p.add_argument('--db', default=str(DEFAULT_DB),
                   help='Path to ble_history.db')
    return p.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv if argv is not None else sys.argv[1:])

    db_path = Path(args.db)
    if not db_path.exists():
        sys.stderr.write(f"history DB missing: {db_path}\n")
        return 1

    kw: dict = {'limit': max(1, min(args.limit, 100000))}
    if args.target:
        kw['target'] = args.target
    if args.drive_id:
        kw['drive_id'] = args.drive_id
    try:
        if args.since:
            kw['since'] = ble_history.parse_relative(args.since)
        if args.until:
            kw['until'] = ble_history.parse_relative(args.until)
    except ValueError as e:
        sys.stderr.write(f"--since/--until: {e}\n")
        return 1

    conn = ble_history.open_db(db_path)
    try:
        rows = ble_history.query_history(conn, **kw)
    finally:
        conn.close()

    if not rows:
        sys.stderr.write("no detections matched filters\n")
        return 2

    if args.format == 'csv':
        out = ble_history.to_csv(rows)
    elif args.format == 'geojson':
        out = json.dumps(ble_history.to_geojson(rows), indent=2)
    else:  # json
        out = json.dumps(rows, indent=2, default=str)

    if args.out and args.out != '-':
        Path(args.out).write_text(out, encoding='utf-8')
        sys.stderr.write(f"wrote {len(rows)} row(s) to {args.out}\n")
    else:
        sys.stdout.write(out)

    return 0


if __name__ == '__main__':
    raise SystemExit(main())
