<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material3 + edge-to-edge; Compose owns the real theming at runtime.
         This base theme just gives the splash/launch window sane colors. -->
    <style name="Theme.Drifter" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/ic_launcher_background</item>
        <item name="android:navigationBarColor">@color/ic_launcher_background</item>
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>
</resources>
