# MZ1312 DRIFTER — Environment overrides
# UNCAGED TECHNOLOGY — EST 1991
#
# Copy to /opt/drifter/.env (or ~/.env) and fill in only what you need.
# All keys are optional; defaults in src/config.py keep the stack
# offline-only and zero-cloud out of the box.
#
# Read by src/config.py at import time, then re-exported as
# UPPER_SNAKE_CASE constants.

# ── Cloud LLM (off by default) ────────────────────────────────────────
# Setting either of these does NOT route Vivi traffic off the Pi —
# Vivi always uses the local Ollama backend defined in vivi.yaml.
# These keys are consumed by src/llm_client.py for off-vehicle dev only.
GROQ_API_KEY=
ANTHROPIC_API_KEY=
# "ollama" (offline-first, default) | "groq" (cloud-first; needs GROQ_API_KEY)
LLM_PRIMARY=ollama

# ── Ollama backend ────────────────────────────────────────────────────
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=300
OLLAMA_KEEP_ALIVE=30m

# ── BLE scanner tunables ──────────────────────────────────────────────
# 1/true/yes to publish full payloads on drifter/ble/raw (debug only —
# bumps MQTT load and writes are persisted unless home_sync excludes
# the topic, which it does by default).
BLE_RAW_PUBLISH=false
BLE_LOG_RETENTION_DAYS=30
BLE_RATE_LIMIT_SEC=30
BLE_GPS_FRESH_SEC=10
