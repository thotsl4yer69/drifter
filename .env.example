# MZ1312 DRIFTER — secrets template
# Copy to /opt/drifter/.env on the Pi (chmod 600). systemd loads it via
# EnvironmentFile; .env is git-ignored. Leave a line blank/absent to let the
# owning service idle (it degrades gracefully — see src/api_keys.have_key).
#
# These keys are PRIVATE — never commit real values. Rotate in the provider
# console if they leak.

# OpenWeatherMap One Call (weather_service.py → drifter/weather/*)
OPENWEATHERMAP_API_KEY=

# Google Maps Platform — Elevation + Places (location_service.py → drifter/location/*)
GOOGLE_MAPS_API_KEY=

# Google Earth Engine — reserved, no live caller yet
GOOGLE_EARTH_ENGINE_API_KEY=

# Wi-Fi hotspot PSK (consumed by install.sh / NetworkManager)
DRIFTER_HOTSPOT_PSK=
