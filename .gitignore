__pycache__/
.pytest_cache/
*.pyc
*.pyo
venv/
.env
logs/
*.log
*.wav
*.db
*.onnx
*.onnx.json
calibration.json
settings.json
tpms_sensors.json
data/
# ...but the mechanic knowledge-base lives under src/data/mechanic and
# IS source code — track it explicitly.
!src/data/
!src/data/**
# cockpit-v4's data adapter is source code, not a runtime data dir — track it.
!cockpit-v4/src/data/
!cockpit-v4/src/data/**
# The Android app's Kotlin `data/` package is ALSO source — without this the
# unanchored `data/` rule swallows the whole data layer (models, net clients,
# repository) and ships a non-compiling app.
!android/app/src/main/java/com/mz1312/drifter/data/
!android/app/src/main/java/com/mz1312/drifter/data/**
reports/
.vscode/
.idea/

# OMC/superpowers runtime — local agent state, not for the repo
.omc/
.superpowers/

# Feature-side additions
.claude/
.venv/
outputs/
